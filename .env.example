# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Application URL
# For local development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For production, update to your Vercel domain
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Discord OAuth (configured in Supabase)
# Create a Discord application at https://discord.com/developers/applications
# Then add the credentials to Supabase: Authentication > Providers > Discord
# Client ID and Secret go in Supabase dashboard, not here

# Discord Bot Token (for sending DMs)
# Create a bot at https://discord.com/developers/applications
# Go to "Bot" tab, copy the token, and add bot to your server with "Send Messages" permission
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Note: After creating your Supabase project:
# 1. Copy .env.example to .env.local
# 2. Fill in your actual Supabase URL and anon key
# 3. Configure Discord OAuth in Supabase dashboard
# 4. Add your Discord bot token to .env.local
